{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://ploinky.local/local-llm-architectures/architecture.schema.json",
    "title": "Architecture record",
    "type": "object",
    "additionalProperties": false,
    "required": ["id", "status", "platform", "accelerator", "image"],
    "properties": {
        "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$",
            "description": "Architecture id passed through PLOINKY_LLM_ARCHITECTURE_ID. Recommended shape: <accelerator-family>[-runtime-or-backend-variant]-<cpu-architecture>, for example cpu-amd64 or nvidia-cuda-cdi-amd64."
        },
        "status": { "enum": ["stable", "experimental"] },
        "platform": { "enum": ["linux/amd64", "linux/arm64"] },
        "accelerator": {
            "type": "object",
            "additionalProperties": false,
            "required": ["family"],
            "properties": {
                "family": { "enum": ["cpu", "nvidia-cuda", "amd-rocm", "vulkan", "intel-openvino"] },
                "minimumComputeCapability": { "type": "string", "maxLength": 16 }
            }
        },
        "match": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "requiredProbes": {
                    "type": "array",
                    "items": { "type": "string", "pattern": "^[a-z][a-zA-Z0-9_.-]{0,63}$" }
                },
                "containerRuntimes": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "enum": ["docker", "podman"] }
                }
            }
        },
        "image": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$" },
        "runtimePolicy": { "$ref": "runtime-policy.schema.json" },
        "engineDefaults": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "enginePort": { "type": "integer", "minimum": 1, "maximum": 65535 },
                "runtimePort": { "type": "integer", "minimum": 1, "maximum": 65535 }
            }
        },
        "fallbackPriority": { "type": "integer", "minimum": 0, "maximum": 1000 }
    }
}
