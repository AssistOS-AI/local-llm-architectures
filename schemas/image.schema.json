{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://ploinky.local/local-llm-architectures/image.schema.json",
    "title": "Image record",
    "type": "object",
    "additionalProperties": false,
    "required": ["id", "ref"],
    "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$" },
        "ref": { "type": "string", "minLength": 1, "maxLength": 512 },
        "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "platform": { "enum": ["linux/amd64", "linux/arm64"] },
        "build": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "context": { "type": "string", "maxLength": 256 },
                "dockerfile": { "type": "string", "maxLength": 256 }
            }
        }
    }
}
